{
  "info": {
    "name": "TaskFlow API",
    "description": "Complete API collection for TaskFlow task management system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"John Doe\", \"email\": \"john@example.com\", \"password\": \"SecurePass123\"}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"john@example.com\", \"password\": \"SecurePass123\"}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/projects?page=1&limit=20",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["projects"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"TaskFlow Development\", \"description\": \"Building the main API\"}"
            },
            "url": {
              "raw": "http://localhost:3000/projects",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["projects"]
            }
          }
        },
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/projects/{{project_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["projects", "{{project_id}}"]
            }
          }
        },
        {
          "name": "Get Project Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/projects/{{project_id}}/stats",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["projects", "{{project_id}}", "stats"]
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/projects/{{project_id}}/tasks?status=todo&assignee={{user_id}}&page=1&limit=20",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["projects", "{{project_id}}", "tasks"],
              "query": [
                {
                  "key": "status",
                  "value": "todo"
                },
                {
                  "key": "assignee",
                  "value": "{{user_id}}"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Implement authentication\", \"description\": \"Add JWT authentication\", \"status\": \"todo\", \"priority\": \"high\", \"dueDate\": \"2024-04-20\"}"
            },
            "url": {
              "raw": "http://localhost:3000/projects/{{project_id}}/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["projects", "{{project_id}}", "tasks"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "",
      "description": "JWT token from login response"
    },
    {
      "key": "project_id",
      "value": "",
      "description": "Project ID from list or create response"
    },
    {
      "key": "user_id",
      "value": "",
      "description": "User ID from login or register response"
    }
  ]
}
