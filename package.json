{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "Production-grade task management REST API",
  "main": "backend/src/app.js",
  "type": "module",
  "scripts": {
    "start": "pm2 start backend/src/app.js --name taskflow --watch --env production",
    "dev": "nodemon backend/src/app.js",
    "migrate:up": "node scripts/migrate.js up",
    "migrate:down": "node scripts/migrate.js down",
    "seed": "node scripts/seed.js",
    "test": "NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:watch": "NODE_ENV=test jest --watch",
    "lint": "eslint backend/src",
    "docker:build": "docker build -t taskflow:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "nodejs",
    "express",
    "postgresql",
    "rest-api",
    "task-management"
  ],
  "author": "Pratiksha",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.0",
    "nodemon": "^3.1.14",
    "pg": "^8.11.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "pm2": "^6.0.14",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
